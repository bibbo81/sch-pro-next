# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ShipsGo API Configuration
SHIPSGO_API_KEY=your_shipsgo_api_key

# Application URL (for cron jobs)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Cron Job Security (generate a random string)
CRON_SECRET=your_random_secret_string

# Database (if needed for direct access)
DATABASE_URL=your_database_url

# Super Admin activation codes (comma-separated, generate new random codes)
SUPER_ADMIN_ACTIVATION_CODES=code1,code2,code3

# API Keys encryption key (generate a random 32+ char string, REQUIRED)
API_KEYS_ENCRYPTION_KEY=your_random_encryption_key_at_least_32_chars